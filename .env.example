# =============================================================================
# Parking SaaS — Client (frontend organización + UI)
# Copiar a .env. Nunca subir .env al repositorio.
# =============================================================================

# API — en desarrollo usar el proxy de Vite (/api → core)
VITE_API_URL=/api

# En Vercel (Build Environment Variables), usa la URL REAL de tu proyecto core:
# VITE_API_URL=https://parking-saas-core-XXXX.vercel.app/api
# (Si omites /api, el client lo añade solo. NO uses placeholders tipo tu-backend.)

# Aplicación
VITE_APP_NAME=Parking SaaS
# URL pública (política de privacidad / SEO). En local puedes usar http://localhost:5173
VITE_APP_URL=https://parking-saas-client.vercel.app
