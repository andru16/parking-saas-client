# =============================================================================
# Parking SaaS — Client (frontend organización + UI)
# Copiar a .env. Nunca subir .env al repositorio.
# =============================================================================

# API — en desarrollo usar el proxy de Vite (/api → core)
# En producción (Vercel): URL absoluta del API incluyendo /api
# Ejemplo: https://parking-api.vercel.app/api
VITE_API_URL=/api

# Aplicación
VITE_APP_NAME=Parking SaaS
# Producción: URL pública del frontend en Vercel
VITE_APP_URL=http://localhost:5173
